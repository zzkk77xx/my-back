# Copy to .env and fill in your values

# 0x-prefixed address of your Gnosis Safe multisig
SAFE_ADDRESS=0x...

# ERC-20 token contract address to withdraw
TOKEN_ADDRESS=0x...

# Amount in the token's smallest unit (e.g. 1 USDC = 1000000 if 6 decimals)
AMOUNT=1000000

# Optional: SQLite wallet database path (default: ./data/wallet.db)
# DB_PATH=./data/wallet.db

# Optional: HTTP server port (default: 3000)
# PORT=3000
