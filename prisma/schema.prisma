generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

// Persisted SpendAuthorized on-chain events + withdrawal execution state
model SpendAuthorizedEvent {
  id              Int      @id @default(autoincrement())
  blockNumber     BigInt
  txHash          String   @db.VarChar(66)
  logIndex        Int
  contractAddress String   @db.VarChar(42)
  m2              String   @db.VarChar(42)
  eoa             String   @db.VarChar(42)
  amount          String   // uint256 (18-decimal USD) as decimal string
  recipientHash   String   @db.VarChar(66)
  transferType    Int
  nonce           String   // uint256 as decimal string
  createdAt       DateTime @default(now())

  // Withdrawal execution tracking
  // Status: "pending" | "processing" | "done" | "failed" | "no_recipient" | "dead_letter"
  withdrawalStatus  String  @default("pending")
  withdrawalRelayId String? // relayId from Unlink once submitted
  withdrawalError   String? // error message if status = "failed"

  // Retry logic
  retryCount  Int       @default(0)
  nextRetryAt DateTime?

  // Timing decorrelation — random delay before execution
  scheduledAt DateTime?

  @@unique([txHash, logIndex])
  @@map("spend_authorized_events")
}

// Contract addresses the event watcher monitors.
// Each contract maps to a specific ERC-20 token in the Unlink pool.
model WatchedContract {
  address      String  @id @db.VarChar(42)
  label        String?
  tokenAddress String  @db.VarChar(42) // ERC-20 token for Unlink withdrawal
  tokenDecimals Int    @default(6)     // decimals for amount conversion (USDC = 6)
  createdAt    DateTime @default(now())

  @@map("watched_contracts")
}

// Maps on-chain recipientHash (bytes32) → actual withdrawal recipient address.
// The hash is computed off-chain before calling authorizeSpend().
model RecipientMapping {
  hash      String   @id @db.VarChar(66) // keccak256 hex (0x-prefixed)
  address   String   @db.VarChar(42)     // 0x-prefixed EOA recipient
  label     String?
  createdAt DateTime @default(now())

  @@map("recipient_mappings")
}

// Registered users and their deployed 2/2 Safe addresses
model User {
  id                     Int      @id @default(autoincrement())
  address                String   @unique @db.VarChar(42) // user EOA
  safeAddress            String   @db.VarChar(42)         // deployed 2/2 Safe
  spendInteractorAddress String   @db.VarChar(42)         // SpendInteractor module for this Safe
  accountNumber          Int?     @unique                 // public-facing bank account number (starts at 100000)
  createdAt              DateTime @default(now())

  @@map("users")
}

// Watcher state (last processed block, etc.)
model Meta {
  key   String @id
  value String

  @@map("meta")
}

// Per-user deposited balance (what they can spend)
model UserBalance {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @db.VarChar(42) // "usd" for USD-denominated, or token address
  balance   String                    // decimal string, 18 decimals
  updatedAt DateTime @updatedAt

  @@unique([userId, token])
  @@map("user_balances")
}

// Immutable ledger of all balance mutations
model BalanceLedger {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @db.VarChar(42)
  type      String   // "deposit" | "spend" | "refund"
  amount    String   // decimal string, 18 decimals
  reference String?  // txHash or relayId
  note      String?
  createdAt DateTime @default(now())

  @@map("balance_ledger")
}

// Backend-generated card EOAs — private key stored server-side
model CardEoa {
  id         Int      @id @default(autoincrement())
  userId     Int
  address    String   @unique @db.VarChar(42) // 0x-prefixed derived address
  privateKey String   @db.VarChar(66)         // 0x-prefixed hex private key
  dailyLimit String                            // 18-decimal wei string
  createdAt  DateTime @default(now())

  @@index([userId])
  @@map("card_eoas")
}

// M1 internal trading desk sub-accounts managed by bank operators
model SubAccount {
  id           Int      @id @default(autoincrement())
  name         String
  operator     String
  balance      Float    @default(0)
  deployed     Float    @default(0)
  dailyLimit   Float    @default(500000)
  spentToday   Float    @default(0)
  status       String   @default("active") // active | paused | disabled
  protocols    String   @default("[]")      // JSON array of protocol ids
  pnl          Float    @default(0)
  perfData     String   @default("[]")      // JSON array of { month, returnPct, monthReturn }
  lastActivity DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("sub_accounts")
}

// Per-user beneficiary registry (known recipients)
model BeneficiaryRegistry {
  id            Int      @id @default(autoincrement())
  userId        Int
  recipientHash String   @db.VarChar(66) // keccak256(abi.encodePacked(address))
  address       String   @db.VarChar(42) // actual 0x-prefixed recipient
  label         String?
  status        String   @default("approved") // "approved" | "pending" | "blocked"
  createdAt     DateTime @default(now())

  @@unique([userId, recipientHash])
  @@index([userId])
  @@map("beneficiary_registry")
}

// Compliance audit trail for all auto-sign / pool / withdrawal decisions
model AuditLog {
  id        Int      @id @default(autoincrement())
  action    String   // auto_sign_approved | auto_sign_rejected | withdrawal_executed | withdrawal_failed | deposit_recorded | pool_topup | pool_topup_failed
  userId    Int?
  details   String   // JSON blob
  createdAt DateTime @default(now())

  @@index([action])
  @@index([userId])
  @@map("audit_logs")
}
