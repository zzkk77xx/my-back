# Copy to .env and fill in your values

# ── Unlink wallet ──────────────────────────────────────────────────────────────
# 24-word BIP-39 mnemonic — wallet state is re-derived from this on every boot
UNLINK_MNEMONIC="word1 word2 ... word24"

# 0x-prefixed default withdrawal recipient (Gnosis Safe multisig address)
SAFE_ADDRESS=0x...

# ── Database ───────────────────────────────────────────────────────────────────
# PostgreSQL connection string (PlanetScale, Neon, Supabase, etc.)
DATABASE_URL="postgresql://..."

# ── Safe deployment ────────────────────────────────────────────────────────────
# 0x-prefixed private key of the admin EOA (co-owner of all user Safes + pays deployment gas)
ADMIN_PRIVATE_KEY=0x...

# Chain ID for Safe deployment (default: 10143 for monad-testnet)
# CHAIN_ID=10143

# ── Blockchain event watcher ───────────────────────────────────────────────────
# Monad testnet HTTP JSON-RPC endpoint
RPC_URL="https://..."

# Envio GraphQL endpoint (recommended — Monad limits getLogs to 100-1000 blocks)
# When set, the watcher queries Envio instead of calling getLogs directly.
# Run the indexer from Bank/indexer/ (see Bank repo README).
ENVIO_GRAPHQL_URL=http://localhost:8080/v1/graphql

# Block number to start watching from on first run (default: latest block)
# WATCHER_START_BLOCK=0

# How often to poll for new events in ms (default: 10000)
# WATCHER_POLL_INTERVAL_MS=10000

# ── Privy auth ─────────────────────────────────────────────────────────────────
# Found in the Privy dashboard (same App ID as VITE_PRIVY_APP_ID in the frontend)
PRIVY_APP_ID=...
PRIVY_APP_SECRET=...

# ── Server ─────────────────────────────────────────────────────────────────────
# HTTP port (default: 3000)
# PORT=3000

# ── One-shot withdraw script ───────────────────────────────────────────────────
# TOKEN_ADDRESS=0x...
# AMOUNT=1000000
