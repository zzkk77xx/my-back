# Copy to .env and fill in your values

# ── Unlink wallet ──────────────────────────────────────────────────────────────
# 24-word BIP-39 mnemonic — wallet state is re-derived from this on every boot
UNLINK_MNEMONIC="word1 word2 ... word24"

# 0x-prefixed default withdrawal recipient (Gnosis Safe multisig address)
SAFE_ADDRESS=0x...

# ── Database ───────────────────────────────────────────────────────────────────
# PostgreSQL connection string (PlanetScale, Neon, Supabase, etc.)
DATABASE_URL="postgresql://..."

# ── Safe deployment ────────────────────────────────────────────────────────────
# 0x-prefixed private key of the admin EOA (co-owner of all user Safes + pays deployment gas)
ADMIN_PRIVATE_KEY=0x...

# Chain ID for Safe deployment (default: 10143 for monad-testnet)
# CHAIN_ID=10143

# ── Blockchain event watcher ───────────────────────────────────────────────────
# Monad testnet HTTP JSON-RPC endpoint
RPC_URL="https://..."

# Envio GraphQL endpoint (recommended — Monad limits getLogs to 100-1000 blocks)
# When set, the watcher queries Envio instead of calling getLogs directly.
# Run the indexer from Bank/indexer/ (see Bank repo README).
ENVIO_GRAPHQL_URL=http://localhost:8080/v1/graphql

# Block number to start watching from on first run (default: latest block)
# WATCHER_START_BLOCK=0

# How often to poll for new events in ms (default: 10000)
# WATCHER_POLL_INTERVAL_MS=10000

# ── Privy auth ─────────────────────────────────────────────────────────────────
# Found in the Privy dashboard (same App ID as VITE_PRIVY_APP_ID in the frontend)
PRIVY_APP_ID=...
PRIVY_APP_SECRET=...

# ── Server ─────────────────────────────────────────────────────────────────────
# HTTP port (default: 3000)
# PORT=3000
# Allowed CORS origin (default: http://localhost:5173)
# CORS_ORIGIN=https://your-frontend.com

# ── Timing decorrelation ──────────────────────────────────────────────────────
# Random delay range (ms) between event detection and execution (privacy)
# DECORRELATION_MIN_MS=5000
# DECORRELATION_MAX_MS=30000

# ── Velocity limits ──────────────────────────────────────────────────────────
# Rolling spend limits in 18-decimal USD (default: 50k 7d, 150k 30d)
# VELOCITY_7D_LIMIT_USD=50000000000000000000000
# VELOCITY_30D_LIMIT_USD=150000000000000000000000

# ── Pool management ──────────────────────────────────────────────────────────
# Private key of the funder wallet for JIT pool top-ups (0x-prefixed)
# POOL_FUNDER_PRIVATE_KEY=0x...
# ERC-20 token to monitor in the Unlink pool (e.g. USDC address)
# POOL_TOKEN_ADDRESS=0x...
# Pool balance threshold that triggers auto top-up (in token units, e.g. 1000000000 = 1000 USDC)
# POOL_LOW_WATER_MARK=1000000000
# Amount to deposit on each top-up (token units)
# POOL_TOP_UP_AMOUNT=5000000000
# High-water mark: sweep excess above this to M1 Safe (0 = disabled)
# POOL_HIGH_WATER_MARK=0
# Sweep recipient address (defaults to SAFE_ADDRESS)
# POOL_SWEEP_RECIPIENT=0x...
# Check interval in ms (default: 60000)
# POOL_CHECK_INTERVAL_MS=60000

# ── Default token (user onboarding) ─────────────────────────────────────────
# Default ERC-20 token for auto-registering WatchedContract on user signup.
# Falls back to POOL_TOKEN_ADDRESS if not set.
# DEFAULT_TOKEN_ADDRESS=0x...
# Decimals for the default token (default: 6 for USDC)
# DEFAULT_TOKEN_DECIMALS=6

# ── One-shot withdraw script ───────────────────────────────────────────────────
# TOKEN_ADDRESS=0x...
# AMOUNT=1000000
